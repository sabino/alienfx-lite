<Window x:Class="AlienFxLite.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="AlienFx Lite"
        Width="1200"
        Height="760"
        MinWidth="1040"
        MinHeight="680"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        Background="#080C13">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#E8EEF7"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#98A7C2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#00D6FF"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#00FFC8"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF7896"/>
        <SolidColorBrush x:Key="GlassBrush" Color="#77141C2B"/>
        <SolidColorBrush x:Key="GlassAltBrush" Color="#66202A3A"/>
        <SolidColorBrush x:Key="BorderBrushGlass" Color="#425574"/>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource GlassBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushGlass}"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="GlassButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#66212D3F"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushGlass}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#88314158"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#AA243247"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
            <Setter Property="Background" Value="#AA12677A"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="18,14"/>
        </Style>

        <Style x:Key="ZoneToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#66303D52"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushGlass}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ZoneChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ZoneChrome" Property="Background" Value="#B8176B82"/>
                                <Setter TargetName="ZoneChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ZoneChrome" Property="Background" Value="#88303F57"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#09111A" Offset="0"/>
                <GradientStop Color="#0A101C" Offset="0.45"/>
                <GradientStop Color="#111A2A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas IsHitTestVisible="False">
            <Ellipse Width="380" Height="380" Canvas.Left="-40" Canvas.Top="-70">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#5523C0FF" Offset="0"/>
                        <GradientStop Color="#001A3A63" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="96"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="320" Height="320" Canvas.Right="-60" Canvas.Bottom="-40">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4014FFC8" Offset="0"/>
                        <GradientStop Color="#000E2F2B" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Padding="22" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextBrush}" FontFamily="Bahnschrift SemiBold" FontSize="28" Text="AlienFx Lite"/>
                        <TextBlock Foreground="{StaticResource MutedBrush}" Margin="0,6,0,12" Text="Minimal control with a cleaner visual surface and persistent hardware state."/>
                        <TextBlock x:Name="ServiceStatusText" Foreground="{StaticResource AccentStrongBrush}" FontFamily="Bahnschrift SemiBold" FontSize="13"/>
                        <TextBlock x:Name="DeviceStatusText" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button x:Name="RefreshButton" Grid.Column="1" Style="{StaticResource GlassButtonStyle}" Width="120" Height="52" Click="RefreshButton_Click" Content="Refresh"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="0.85*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}" Padding="22" Margin="0,0,14,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Keyboard Zones"/>
                            <TextBlock Style="{StaticResource SectionHintStyle}" Margin="0,6,0,0" Text="The deck below is the live selection surface. Choose the exact zone set before you apply."/>
                        </StackPanel>

                        <Border Grid.Row="1" Margin="0,18,0,18" Style="{StaticResource GlassCardStyle}" Background="{StaticResource GlassAltBrush}" Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.23*"/>
                                    <ColumnDefinition Width="0.27*"/>
                                    <ColumnDefinition Width="0.27*"/>
                                    <ColumnDefinition Width="0.23*"/>
                                </Grid.ColumnDefinitions>
                                <primitives:ToggleButton x:Name="LeftZoneButton" Grid.Column="0" Style="{StaticResource ZoneToggleStyle}" Margin="0,0,8,0" Checked="ZoneButton_Changed" Unchecked="ZoneButton_Changed" Content="KB LEFT"/>
                                <primitives:ToggleButton x:Name="CenterZoneButton" Grid.Column="1" Style="{StaticResource ZoneToggleStyle}" Margin="8,0" Checked="ZoneButton_Changed" Unchecked="ZoneButton_Changed" Content="KB CENTER"/>
                                <primitives:ToggleButton x:Name="RightZoneButton" Grid.Column="2" Style="{StaticResource ZoneToggleStyle}" Margin="8,0" Checked="ZoneButton_Changed" Unchecked="ZoneButton_Changed" Content="KB RIGHT"/>
                                <primitives:ToggleButton x:Name="NumPadZoneButton" Grid.Column="3" Style="{StaticResource ZoneToggleStyle}" Margin="8,0,0,0" Checked="ZoneButton_Changed" Unchecked="ZoneButton_Changed" Content="KB NUMPAD"/>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="LightingHintText" Grid.Row="2" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.56*"/>
                        <RowDefinition Height="0.24*"/>
                        <RowDefinition Height="0.20*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Padding="22" Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Lighting Deck"/>
                                <TextBlock Style="{StaticResource SectionHintStyle}" Margin="0,6,0,16" Text="Change the effect, tune the colors, then commit through the primary action."/>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="EFFECT"/>
                                <ComboBox x:Name="EffectCombo" Grid.Column="1" Height="34" Background="#55212E42" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrushGlass}" SelectionChanged="EffectCombo_SelectionChanged"/>
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="PRIMARY"/>
                                    <Button x:Name="PrimaryColorButton" Style="{StaticResource GlassButtonStyle}" Height="44" Click="PrimaryColorButton_Click"/>
                                </StackPanel>
                                <StackPanel x:Name="SecondaryPanel" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="SECONDARY"/>
                                    <Button x:Name="SecondaryColorButton" Style="{StaticResource GlassButtonStyle}" Height="44" Click="SecondaryColorButton_Click"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="3" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="EFFECT SPEED"/>
                                <Slider x:Name="SpeedSlider" Grid.Column="1" Minimum="0" Maximum="100" ValueChanged="SpeedSlider_ValueChanged"/>
                                <TextBlock x:Name="SpeedValueText" Grid.Column="2" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="BRIGHTNESS"/>
                                <Slider x:Name="BrightnessSlider" Grid.Column="1" Minimum="0" Maximum="100" ValueChanged="BrightnessSlider_ValueChanged"/>
                                <TextBlock x:Name="BrightnessValueText" Grid.Column="2" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Grid.Row="5" Background="#44202A38" CornerRadius="18" Padding="14">
                                <StackPanel>
                                    <CheckBox x:Name="KeepAliveCheck" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" Checked="SettingChanged" Unchecked="SettingChanged" Content="Maintain keyboard state"/>
                                    <CheckBox x:Name="EnabledCheck" Foreground="{StaticResource TextBrush}" Checked="SettingChanged" Unchecked="SettingChanged" Content="Lights enabled"/>
                                    <Button x:Name="ApplyLightingButton" Margin="0,16,0,0" Height="56" Style="{StaticResource PrimaryButtonStyle}" Click="ApplyLightingButton_Click" Content="APPLY LIGHTING"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}" Padding="22" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Thermals"/>
                            <TextBlock Style="{StaticResource SectionHintStyle}" Margin="0,6,0,14" Text="Use BIOS/AUTO to hand control back. MAX pushes the detected fans to full raw boost."/>
                            <TextBlock x:Name="FanModeText" Foreground="{StaticResource TextBrush}" FontFamily="Bahnschrift SemiBold"/>
                            <TextBlock x:Name="FanRpmText" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Button x:Name="FanAutoButton" Style="{StaticResource GlassButtonStyle}" Margin="0,0,8,0" Click="FanAutoButton_Click" Content="BIOS / AUTO"/>
                                <Button x:Name="FanMaxButton" Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0" Click="FanMaxButton_Click" Content="MAX"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource GlassCardStyle}" Padding="22">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Live State"/>
                            <TextBlock x:Name="PendingText" Foreground="{StaticResource MutedBrush}" Margin="0,10,0,10" TextWrapping="Wrap"/>
                            <TextBlock x:Name="FanHintText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <TextBlock Grid.Row="2"
                       Margin="0,16,0,0"
                       Foreground="{StaticResource MutedBrush}"
                       Text="If a zone still blinks white after apply, the keyboard firmware is still replaying a conflicting raw light state."
                       TextWrapping="Wrap"/>
        </Grid>
    </Grid>
</Window>
